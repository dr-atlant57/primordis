<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Case Library — PRIMORDIS</title>
<meta name="description" content="Structured case observations from the PRIMORDIS clinical archive. Each case documents configuration, compensation chain, timeline and follow-up.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --maxw:1080px;
  --font-display:'Spectral',Georgia,serif;
  --font-body:'IBM Plex Sans',-apple-system,'Segoe UI',sans-serif;
  --font-mono:'IBM Plex Mono','SF Mono',monospace;
}
html[data-theme="dark"]{
  --bg:#101418;--bg-soft:#141A20;--surface:#1A2129;--surface-2:#1F2731;
  --text:#E6EAED;--text-soft:#C3CBD2;--muted:#8E99A3;
  --line:#2B343E;--line-soft:#222B34;
  --accent:#D2904F;--accent-soft:rgba(210,144,79,.13);--accent-2:#86A9BD;
  --header-bg:rgba(16,20,24,.84);--shadow:0 12px 36px rgba(0,0,0,.4);
  --img-bg:#0C1014;
}
html[data-theme="light"]{
  --bg:#F2F3F1;--bg-soft:#ECEEEC;--surface:#FAFBFA;--surface-2:#FFFFFF;
  --text:#21262B;--text-soft:#3A434B;--muted:#5C6770;
  --line:#D7DCDE;--line-soft:#E2E6E7;
  --accent:#A05A19;--accent-soft:rgba(160,90,25,.09);--accent-2:#3E6478;
  --header-bg:rgba(242,243,241,.88);--shadow:0 10px 30px rgba(30,40,50,.08);
  --img-bg:#1A1F24;
}
*{margin:0;padding:0;box-sizing:border-box;}
html,body{overflow-x:hidden;scroll-behavior:smooth;}
body{background:var(--bg);color:var(--text);font-family:var(--font-body);font-size:16px;line-height:1.65;-webkit-font-smoothing:antialiased;transition:background .3s,color .3s;}
::selection{background:var(--accent-soft);}
a{color:inherit;text-decoration:none;}

/* spine */
.spine{position:fixed;left:34px;top:0;bottom:0;width:1px;background:var(--line-soft);z-index:0;pointer-events:none;}
@media(max-width:1180px){.spine{display:none;}}

/* ── header ─────────────────────────────────────────────── */
header{position:sticky;top:0;z-index:50;background:var(--header-bg);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border-bottom:1px solid var(--line-soft);}
.header-in{max-width:var(--maxw);margin:0 auto;padding:0 24px;height:64px;display:flex;align-items:center;gap:20px;}
.logo{display:flex;align-items:center;gap:11px;text-decoration:none;flex:none;}
.logo-mark{width:14px;height:26px;position:relative;flex:none;}
.logo-mark::before{content:"";position:absolute;left:50%;top:0;bottom:0;width:1.5px;background:var(--text);transform:translateX(-50%);}
.logo-mark::after{content:"";position:absolute;left:50%;top:5px;width:7px;height:7px;border-radius:50%;background:var(--accent);transform:translateX(calc(-50% + 4px));}
.logo-word{font-weight:600;letter-spacing:.22em;font-size:14px;}
nav.main{display:flex;align-items:center;gap:2px;margin-left:auto;overflow:hidden;}
nav.main a{font-size:12px;color:var(--muted);text-decoration:none;padding:5px 8px;border-radius:6px;white-space:nowrap;transition:color .18s,background .18s;}
nav.main a:hover{color:var(--text);background:var(--surface);}
nav.main a.active{color:var(--accent);}
nav.main a.nav-term{font-family:var(--font-mono);font-size:11px;color:var(--accent);border:1px solid var(--accent-soft);border-radius:5px;padding:4px 7px;letter-spacing:.04em;}
nav.main a.nav-term:hover{background:var(--accent-soft);}
.controls{display:flex;align-items:center;gap:8px;flex:none;margin-left:12px;}
.lang{display:flex;flex-wrap:wrap;border:1px solid var(--line);border-radius:7px;overflow:hidden;}
.lang button{font-family:var(--font-mono);font-size:12px;padding:4px 7px;border:none;cursor:pointer;background:transparent;color:var(--muted);transition:.18s;flex:1 1 auto;min-width:28px;white-space:nowrap;}
.lang button.on{background:var(--accent-soft);color:var(--accent);font-weight:500;}
.theme-btn{width:32px;height:30px;border:1px solid var(--line);border-radius:7px;cursor:pointer;background:transparent;color:var(--muted);display:flex;align-items:center;justify-content:center;transition:.18s;flex:none;}
.theme-btn:hover{color:var(--text);}
.burger-btn{display:none;width:32px;height:30px;border:1px solid var(--line);border-radius:7px;cursor:pointer;background:transparent;color:var(--muted);align-items:center;justify-content:center;flex:none;transition:.18s;}
.burger-btn:hover{color:var(--text);}
@media(max-width:1180px){nav.main a[href="atlas.html"],nav.main a[href="anthroponomy.html"]{display:none;}}
@media(max-width:980px){nav.main{display:none;}.burger-btn{display:flex;}.controls{margin-left:auto;}.lang{max-width:calc(100vw - 120px);flex-wrap:nowrap;overflow-x:auto;scrollbar-width:none;}.lang::-webkit-scrollbar{display:none;}.lang button{padding:4px 6px;font-size:11.5px;white-space:nowrap;flex:none;}}
@media(max-width:600px){.header-in{padding:0 16px;height:56px;gap:8px;}.lang{max-width:calc(100vw - 120px);}.lang button{padding:3px 5px;font-size:11px;}.theme-btn,.burger-btn{width:30px;height:28px;}}

/* drawer */
.drawer-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:80;opacity:0;transition:opacity .25s;}
.drawer-overlay.open{display:block;opacity:1;}
.mobile-drawer{position:fixed;top:0;right:0;bottom:0;width:min(300px,85vw);background:var(--surface);border-left:1px solid var(--line-soft);z-index:90;transform:translateX(100%);transition:transform .28s ease;display:flex;flex-direction:column;overflow-y:auto;}
.mobile-drawer.open{transform:translateX(0);}
html[dir="rtl"] .mobile-drawer{right:auto;left:0;border-left:none;border-right:1px solid var(--line-soft);transform:translateX(-100%);}
html[dir="rtl"] .mobile-drawer.open{transform:translateX(0);}
.drawer-header{display:flex;align-items:center;justify-content:space-between;padding:20px 20px 16px;border-bottom:1px solid var(--line-soft);}
.drawer-title{font-weight:600;letter-spacing:.18em;font-size:13px;}
.drawer-header button{background:transparent;border:none;cursor:pointer;color:var(--muted);padding:4px;border-radius:5px;display:flex;}
.drawer-links{display:flex;flex-direction:column;padding:12px 8px;flex:1;}
.drawer-links a{font-size:15px;color:var(--text-soft);text-decoration:none;padding:13px 14px;border-radius:8px;transition:background .18s,color .18s;}
.drawer-links a:hover{background:var(--surface-2);color:var(--text);}
.drawer-links a.nav-term{font-family:var(--font-mono);color:var(--accent);font-size:13px;letter-spacing:.06em;}
.drawer-links a.active{color:var(--accent);}
.drawer-lang{padding:16px;border-top:1px solid var(--line-soft);display:flex;flex-wrap:wrap;gap:4px;}
.drawer-lang button{font-family:var(--font-mono);font-size:12px;padding:5px 9px;border:1px solid var(--line);border-radius:5px;cursor:pointer;background:transparent;color:var(--muted);transition:.18s;}
.drawer-lang button.on{background:var(--accent-soft);color:var(--accent);border-color:var(--accent-soft);}

/* layout */
.wrap{max-width:var(--maxw);margin:0 auto;padding:0 24px;position:relative;z-index:1;}
.eyebrow{font-family:var(--font-mono);font-size:13px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);display:flex;align-items:center;gap:12px;margin-bottom:18px;}
.eyebrow::before{content:"";width:26px;height:1px;background:var(--accent);}
h2{font-family:var(--font-display);font-weight:400;font-size:clamp(26px,3.8vw,38px);letter-spacing:-.01em;margin-bottom:16px;}
.lead{font-size:17px;color:var(--text-soft);max-width:700px;}
.note{padding:16px 20px;border-left:2px solid var(--accent);background:var(--accent-soft);border-radius:0 8px 8px 0;font-size:14px;color:var(--text-soft);}
.note b{color:var(--text);}
.btn{display:inline-flex;align-items:center;border-radius:9px;font-size:15px;font-weight:500;padding:13px 24px;transition:.22s;cursor:pointer;border:1px solid transparent;}
.btn-primary{background:var(--accent);color:#14110C;}
html[data-theme="light"] .btn-primary{color:#FFF8F0;}
.btn-primary:hover{filter:brightness(1.08);transform:translateY(-1px);}
.btn-ghost{border-color:var(--line);color:var(--text-soft);}
.btn-ghost:hover{border-color:var(--muted);color:var(--text);}

/* page hero */
.page-hero{padding:80px 0 64px;border-bottom:1px solid var(--line-soft);}
.breadcrumb{font-family:var(--font-mono);font-size:12.5px;color:var(--muted);letter-spacing:.1em;display:flex;align-items:center;gap:8px;margin-bottom:28px;}
.breadcrumb a{color:var(--muted);transition:color .2s;}
.breadcrumb a:hover{color:var(--accent);}
.breadcrumb span{color:var(--line);}
.page-hero h1{font-family:var(--font-display);font-weight:400;font-size:clamp(32px,4.8vw,52px);letter-spacing:-.015em;line-height:1.1;margin-bottom:24px;}
.page-hero h1 em{font-style:italic;color:var(--accent);}

/* library meta */
.lib-meta{margin-top:32px;display:flex;gap:32px;flex-wrap:wrap;}
.lib-stat{font-family:var(--font-mono);font-size:13px;color:var(--muted);}
.lib-stat strong{color:var(--accent);font-size:20px;font-weight:400;display:block;margin-bottom:2px;}

/* case list (index) */
section.case-index{padding:60px 0 0;}
.case-card-link{display:block;text-decoration:none;border-top:1px solid var(--line-soft);transition:background .2s;}
.case-card-link:last-child{border-bottom:1px solid var(--line-soft);}
.case-card-link:hover{background:var(--surface);}
.case-card{display:grid;grid-template-columns:100px 1fr auto;gap:24px;padding:32px 0;align-items:start;}
.case-num{font-family:var(--font-mono);font-size:12px;letter-spacing:.1em;color:var(--muted);}
.case-meta{}
.case-id{font-family:var(--font-mono);font-size:11.5px;color:var(--accent);margin-bottom:6px;letter-spacing:.08em;}
.case-title{font-family:var(--font-display);font-weight:400;font-size:20px;margin-bottom:8px;color:var(--text);}
.case-tags{display:flex;gap:8px;flex-wrap:wrap;}
.case-tag{font-family:var(--font-mono);font-size:11.5px;color:var(--muted);border:1px solid var(--line-soft);border-radius:4px;padding:3px 9px;}
.case-arrow{color:var(--muted);font-size:18px;padding-top:4px;}
@media(max-width:640px){.case-card{grid-template-columns:1fr;gap:12px;}.case-arrow{display:none;}}

/* ── single case ──────────────────────────────────────────── */
section.case-detail{padding:72px 0;border-bottom:1px solid var(--line-soft);}

/* case header block */
.case-header{margin-bottom:52px;}
.case-header-id{font-family:var(--font-mono);font-size:12px;letter-spacing:.14em;color:var(--accent);margin-bottom:16px;}
.case-header h2{font-family:var(--font-display);font-size:clamp(28px,4vw,42px);font-weight:400;margin-bottom:20px;letter-spacing:-.01em;}
.case-header .case-intro{font-size:17px;color:var(--text-soft);max-width:720px;line-height:1.75;}

/* metadata table */
.case-meta-table{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border:1px solid var(--line-soft);border-radius:12px;overflow:hidden;margin:36px 0;}
.meta-cell{padding:20px;border-right:1px solid var(--line-soft);}
.meta-cell:last-child{border-right:none;}
.meta-cell-label{font-family:var(--font-mono);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:6px;}
.meta-cell-val{font-family:var(--font-mono);font-size:14px;color:var(--text);}
.meta-cell-val.accent{color:var(--accent);}
@media(max-width:720px){.case-meta-table{grid-template-columns:repeat(2,1fr);}.meta-cell:nth-child(2){border-right:none;}.meta-cell:nth-child(3){border-top:1px solid var(--line-soft);}}
@media(max-width:400px){.case-meta-table{grid-template-columns:1fr;}.meta-cell{border-right:none;border-top:1px solid var(--line-soft);}.meta-cell:first-child{border-top:none;}}

/* compensation chain visual */
.chain-section{margin:48px 0;}
.chain-section-title{font-family:var(--font-mono);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:24px;display:flex;align-items:center;gap:12px;}
.chain-section-title::before{content:"";width:26px;height:1px;background:var(--accent);}
.chain-flow{display:flex;flex-direction:column;gap:0;}
.chain-item{display:grid;grid-template-columns:200px 1fr;border-top:1px solid var(--line-soft);}
.chain-item:last-child{border-bottom:1px solid var(--line-soft);}
.chain-level{padding:24px;border-right:1px solid var(--line-soft);display:flex;align-items:flex-start;gap:12px;}
.chain-level-arrow{font-family:var(--font-mono);font-size:12px;color:var(--accent);flex:none;padding-top:2px;}
.chain-level-name{font-family:var(--font-mono);font-size:12.5px;color:var(--text-soft);letter-spacing:.04em;line-height:1.5;}
.chain-finding{padding:24px;font-size:14.5px;color:var(--text-soft);line-height:1.7;}
.chain-finding strong{color:var(--text);font-weight:600;}
.chain-item.primary .chain-level{background:var(--accent-soft);}
.chain-item.primary .chain-level-name{color:var(--accent);}
.chain-item.primary .chain-level-arrow{color:var(--accent);}
@media(max-width:640px){.chain-item{grid-template-columns:1fr;}.chain-level{border-right:none;padding-bottom:4px;}.chain-finding{padding-top:6px;}}

/* imaging gallery */
.imaging-section{margin:48px 0;}
.imaging-title{font-family:var(--font-mono);font-size:12px;letter-spacing:.14em;text-transform:uppercase;color:var(--accent);margin-bottom:24px;display:flex;align-items:center;gap:12px;}
.imaging-title::before{content:"";width:26px;height:1px;background:var(--accent);}

/* group layout: label + images */
.imaging-group{margin-bottom:40px;}
.imaging-group-label{font-family:var(--font-mono);font-size:11.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--line-soft);}
.img-grid{display:grid;gap:12px;}
.img-grid.g1{grid-template-columns:1fr;}
.img-grid.g2{grid-template-columns:repeat(2,1fr);}
.img-grid.g3{grid-template-columns:repeat(3,1fr);}
@media(max-width:700px){.img-grid.g2,.img-grid.g3{grid-template-columns:1fr;}}

.img-frame{background:var(--img-bg);border:1px solid var(--line-soft);border-radius:10px;overflow:hidden;position:relative;}
.img-frame img{width:100%;height:auto;display:block;opacity:.92;transition:opacity .25s;}
.img-frame:hover img{opacity:1;}
.img-caption{padding:10px 14px;background:var(--surface);border-top:1px solid var(--line-soft);}
.img-caption-code{font-family:var(--font-mono);font-size:11px;color:var(--accent);display:block;margin-bottom:2px;letter-spacing:.06em;}
.img-caption-text{font-size:13px;color:var(--muted);line-height:1.45;}
/* highlight badge for key measurement */
.img-badge{position:absolute;top:10px;right:10px;background:var(--accent);color:#14110C;font-family:var(--font-mono);font-size:12px;font-weight:600;padding:4px 10px;border-radius:5px;}

/* lightbox */
.lightbox{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:200;align-items:center;justify-content:center;cursor:zoom-out;}
.lightbox.open{display:flex;}
.lightbox img{max-width:90vw;max-height:88vh;object-fit:contain;border-radius:4px;}
.lightbox-close{position:absolute;top:20px;right:24px;background:transparent;border:none;color:#fff;font-size:28px;cursor:pointer;opacity:.7;transition:opacity .2s;}
.lightbox-close:hover{opacity:1;}
.lightbox-caption{position:absolute;bottom:20px;left:50%;transform:translateX(-50%);font-family:var(--font-mono);font-size:13px;color:rgba(255,255,255,.5);white-space:nowrap;}

/* narrative sections */
.narrative{margin:40px 0;}
.narrative p{font-size:15.5px;color:var(--text-soft);line-height:1.8;max-width:740px;margin-bottom:14px;}
.narrative p:last-child{margin-bottom:0;}
.narrative strong{color:var(--text);}

/* observation status */
.obs-status{margin:36px 0;display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.obs-status-item{background:var(--surface);border:1px solid var(--line-soft);border-radius:10px;padding:20px;}
.obs-status-label{font-family:var(--font-mono);font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:8px;}
.obs-status-val{font-size:15px;color:var(--text-soft);line-height:1.5;}
.obs-status-val strong{color:var(--text);}
@media(max-width:620px){.obs-status{grid-template-columns:1fr;}}

/* disclaimer */
.case-disc{margin-top:48px;}

/* more cases placeholder */
section.more-cases{padding:64px 0;}
.more-cases-inner{display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap;}
.more-cases-copy h2{font-family:var(--font-display);font-weight:400;font-size:clamp(22px,3vw,30px);margin-bottom:8px;}
.more-cases-copy p{font-size:15px;color:var(--muted);max-width:480px;}

/* cta */
.cta-strip{padding:64px 0;background:var(--bg-soft);}
.cta-inner{display:flex;align-items:center;justify-content:space-between;gap:32px;flex-wrap:wrap;}
.cta-copy h2{font-family:var(--font-display);font-weight:400;font-size:clamp(22px,3.2vw,32px);margin-bottom:10px;}
.cta-copy p{font-size:16px;color:var(--text-soft);max-width:520px;}

/* footer */
footer{border-top:1px solid var(--line-soft);padding:44px 0 52px;background:var(--bg-soft);}
.foot-grid{display:flex;justify-content:space-between;gap:30px;flex-wrap:wrap;}
.foot-left p{font-size:14px;color:var(--muted);}
.foot-left p:first-child{color:var(--text-soft);font-weight:500;margin-bottom:4px;}
.foot-right{font-family:var(--font-mono);font-size:12.5px;color:var(--muted);text-align:right;line-height:2.2;}
.foot-email a{color:var(--muted);transition:color .2s;}
.foot-email a:hover{color:var(--text);}
@media(max-width:680px){.foot-right{text-align:left;}}

/* reveal */
.reveal{opacity:0;transform:translateY(14px);transition:opacity .65s ease,transform .65s ease;}
.reveal.in{opacity:1;transform:none;}
@media(prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none;transition:none;}html{scroll-behavior:auto;}}
:focus-visible{outline:2px solid var(--accent);outline-offset:3px;border-radius:4px;}

/* RTL */
html[dir="rtl"] .eyebrow,.chain-section-title,.imaging-title{flex-direction:row-reverse;}
html[dir="rtl"] .eyebrow::before,.chain-section-title::before,.imaging-title::before{order:1;}
html[dir="rtl"] .note{border-left:none;border-right:2px solid var(--accent);border-radius:8px 0 0 8px;}
html[dir="rtl"] .chain-level{border-right:none;border-left:1px solid var(--line-soft);}
html[dir="rtl"] .spine{left:auto;right:34px;}

@media(max-width:600px){section.case-detail,.case-index{padding:52px 0 0;}.wrap{padding:0 16px;}.page-hero{padding:48px 0 44px;}}
</style>
</head>
<body>
<div class="spine" aria-hidden="true"></div>

<header>
  <div class="header-in">
    <a class="logo" href="index.html" aria-label="PRIMORDIS home">
      <span class="logo-mark" aria-hidden="true"></span>
      <span class="logo-word">PRIMORDIS</span>
    </a>
    <nav class="main" aria-label="Main navigation">
      <a href="index.html"          data-i18n="nav_home"></a>
      <a href="framework.html"      data-i18n="nav_framework"></a>
      <a href="assessment.html"     data-i18n="nav_assessment"></a>
      <a href="cases.html"          data-i18n="nav_cases" class="active"></a>
      <a href="research.html"       data-i18n="nav_research"></a>
      <a href="primordocciput.html" class="nav-term" data-i18n="nav_primordocciput"></a>
      <a href="atlas.html"          data-i18n="nav_atlas"></a>
      <a href="anthroponomy.html"   data-i18n="nav_anthroponomy"></a>
    </nav>
    <div class="controls">
      <div class="lang" role="group" aria-label="Language">
        <button type="button" data-lang="en">EN</button><button type="button" data-lang="de">DE</button>
        <button type="button" data-lang="ru">RU</button><button type="button" data-lang="es">ES</button>
        <button type="button" data-lang="fr">FR</button><button type="button" data-lang="ar">AR</button>
        <button type="button" data-lang="zh">中文</button><button type="button" data-lang="ja">日本語</button>
        <button type="button" data-lang="ko">한국어</button><button type="button" data-lang="et">ET</button>
        <button type="button" data-lang="lv">LV</button>
      </div>
      <button type="button" class="theme-btn" id="themeBtn" aria-label="Toggle theme">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" id="themeIcon">
          <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/>
        </svg>
